{
  "name": "pr-gate",
  "version": "0.1.0",
  "description": "GitHub Action enforcing Jira-linked PR policies",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "build:watch": "tsc --watch",
    "lint": "eslint src",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^6.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^6.0.3"
  }
}
